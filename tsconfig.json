{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "remix/component",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": ["app/**/*.ts", "app/**/*.tsx"]
}
